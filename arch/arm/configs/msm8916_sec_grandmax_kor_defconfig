CONFIG_SEC_GRANDMAX_PROJECT=y
CONFIG_MACH_GRANDMAX_KOR_OPEN=y

CONFIG_LOCALVERSION="-Churus"
# CONFIG_LOCALVERSION_AUTO is not set

# SS Pinctrl Driver
CONFIG_SEC_GPIO_SETTINGS=y

# MUIC
CONFIG_SM5504_MUIC=y
CONFIG_MUIC_SUPPORT_RUSTPROOF=y
CONFIG_USBID_STANDARD_VER_01=y

# VIBRATOR
CONFIG_MSM_VIBRATOR=y

# Touch Screen
CONFIG_TOUCHSCREEN_IST30XX_O1=y
CONFIG_INPUT_BOOSTER=y
# CONFIG_INPUT_SECLED is not set

# LCD
CONFIG_PANEL_S6D2AA0X_LPM053A250A_HD=y
CONFIG_MFD_ISL98611=y

CONFIG_CABC_TUNING=y
CONFIG_MDNIE_TFT_MSM8X16=y

CONFIG_MFD_RT5033=y
CONFIG_MFD_RT5033_RESET_WA=y
CONFIG_MFD_RT5033_RESET_GPIO=y
CONFIG_MFD_RT5033_SLDO_VBUSDET=y
CONFIG_BATTERY_SAMSUNG=y
